generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               Int                  @id @default(autoincrement())
  name             String               @unique
  createdAt        DateTime             @default(now())
  joinCode         String               @unique @default("")
  activityLogs     ActivityLog[]
  allocations      Allocation[]
  assets           Asset[]
  categories       AssetCategory[]
  auditCycles      AuditCycle[]
  auditItems       AuditItem[]
  bookings         Booking[]
  departments      Department[]
  employees        Employee[]
  maintenanceReqs  MaintenanceRequest[]
  notifications    Notification[]
  roles            Role[]
  transferRequests TransferRequest[]
}

model Department {
  id             Int          @id @default(autoincrement())
  organizationId Int
  name           String
  headId         Int?
  parentId       Int?
  status         Status       @default(ACTIVE)
  createdAt      DateTime     @default(now())
  head           Employee?    @relation("DepartmentHead", fields: [headId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  parent         Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DeptHierarchy")
  employees      Employee[]   @relation("EmployeeDept")

  @@unique([organizationId, name])
}

model Role {
  id             Int          @id @default(autoincrement())
  organizationId Int
  name           String
  permissions    String[]
  employees      Employee[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
}

model AssetCategory {
  id                     Int          @id @default(autoincrement())
  organizationId         Int
  name                   String
  extraFields            Json?
  baseCarbonFootprintKg  Float        @default(100.0)
  expectedLifespanMonths Int          @default(36)
  powerDrawWatts         Float        @default(50.0)
  assets                 Asset[]
  organization           Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
}

model Employee {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  name              String
  email             String               @unique
  passwordHash      String
  departmentId      Int?
  status            Status               @default(ACTIVE)
  createdAt         DateTime             @default(now())
  roleId            Int
  activityLogs      ActivityLog[]
  allocationsHeld   Allocation[]         @relation("CurrentHolder")
  auditsAssigned    AuditCycleAuditor[]
  bookingsMade      Booking[]
  headOf            Department[]         @relation("DepartmentHead")
  department        Department?          @relation("EmployeeDept", fields: [departmentId], references: [id])
  organization      Organization         @relation(fields: [organizationId], references: [id])
  role              Role                 @relation(fields: [roleId], references: [id])
  maintenanceRaised MaintenanceRequest[] @relation("RaisedBy")
  notifications     Notification[]
  transfersFrom     TransferRequest[]    @relation("TransferFrom")
  transfersTo       TransferRequest[]    @relation("TransferTo")
}

model Asset {
  id              Int                  @id @default(autoincrement())
  organizationId  Int
  tag             String
  name            String
  categoryId      Int
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?
  condition       String               @default("Good")
  location        String?
  isBookable      Boolean              @default(false)
  isLendable      Boolean              @default(false)
  photoUrl        String?
  qrPayload       String?
  status          AssetStatus          @default(AVAILABLE)
  lastActivityAt  DateTime             @default(now())
  createdAt       DateTime             @default(now())
  allocations     Allocation[]
  category        AssetCategory        @relation(fields: [categoryId], references: [id])
  organization    Organization         @relation(fields: [organizationId], references: [id])
  intelligence    AssetIntelligence?
  auditItems      AuditItem[]
  bookings        Booking[]
  maintenanceReqs MaintenanceRequest[]

  @@unique([organizationId, tag])
  @@unique([organizationId, serialNumber])
  @@unique([organizationId, qrPayload])
}

model Allocation {
  id                 Int               @id @default(autoincrement())
  organizationId     Int
  assetId            Int
  holderId           Int
  allocatedAt        DateTime          @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  conditionAtReturn  String?
  isActive           Boolean           @default(true)
  asset              Asset             @relation(fields: [assetId], references: [id])
  holder             Employee          @relation("CurrentHolder", fields: [holderId], references: [id])
  organization       Organization      @relation(fields: [organizationId], references: [id])
  transferRequests   TransferRequest[]
}

model TransferRequest {
  id             Int            @id @default(autoincrement())
  organizationId Int
  allocationId   Int
  fromId         Int
  toId           Int
  reason         String?
  status         TransferStatus @default(REQUESTED)
  isCrossDept    Boolean        @default(false)
  requestedAt    DateTime       @default(now())
  resolvedAt     DateTime?
  allocation     Allocation     @relation(fields: [allocationId], references: [id])
  from           Employee       @relation("TransferFrom", fields: [fromId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id])
  to             Employee       @relation("TransferTo", fields: [toId], references: [id])
}

model Booking {
  id             Int           @id @default(autoincrement())
  organizationId Int
  assetId        Int
  bookedById     Int
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus @default(UPCOMING)
  createdAt      DateTime      @default(now())
  asset          Asset         @relation(fields: [assetId], references: [id])
  bookedBy       Employee      @relation(fields: [bookedById], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])

  @@index([assetId, startTime, endTime])
}

model MaintenanceRequest {
  id               Int               @id @default(autoincrement())
  organizationId   Int
  assetId          Int
  raisedById       Int
  issueDescription String
  priority         String            @default("Medium")
  photoUrl         String?
  status           MaintenanceStatus @default(PENDING)
  technicianName   String?
  createdAt        DateTime          @default(now())
  resolvedAt       DateTime?
  aiAssessed       Boolean           @default(false)
  issueCategory    String?
  asset            Asset             @relation(fields: [assetId], references: [id])
  organization     Organization      @relation(fields: [organizationId], references: [id])
  raisedBy         Employee          @relation("RaisedBy", fields: [raisedById], references: [id])
}

model AuditCycle {
  id             Int                 @id @default(autoincrement())
  organizationId Int
  scopeDept      Int?
  scopeLoc       String?
  startDate      DateTime
  endDate        DateTime
  closed         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id])
  auditors       AuditCycleAuditor[]
  items          AuditItem[]
}

model AuditCycleAuditor {
  id           Int        @id @default(autoincrement())
  auditCycleId Int
  employeeId   Int
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  employee     Employee   @relation(fields: [employeeId], references: [id])
}

model AuditItem {
  id             Int                @id @default(autoincrement())
  organizationId Int
  auditCycleId   Int
  assetId        Int
  verification   AuditVerification?
  notes          String?
  asset          Asset              @relation(fields: [assetId], references: [id])
  auditCycle     AuditCycle         @relation(fields: [auditCycleId], references: [id])
  organization   Organization       @relation(fields: [organizationId], references: [id])
}

model Notification {
  id             Int          @id @default(autoincrement())
  organizationId Int
  employeeId     Int
  type           String
  message        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  employee       Employee     @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model ActivityLog {
  id             Int          @id @default(autoincrement())
  organizationId Int
  employeeId     Int
  action         String
  entityType     String
  entityId       Int?
  createdAt      DateTime     @default(now())
  employee       Employee     @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model AssetIntelligence {
  id                 Int      @id @default(autoincrement())
  assetId            Int      @unique
  healthScore        Float    @default(100.0)
  failureProbability Float    @default(0.0)
  carbonFootprintKg  Float    @default(0.0)
  lastCalculatedAt   DateTime @default(now())
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditVerification {
  VERIFIED
  MISSING
  DAMAGED
}

enum Status {
  ACTIVE
  INACTIVE
}
